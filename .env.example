# Runtime mode: development, production, or mock
ASSISTANT_ENV=development
ASSISTANT_HOST=127.0.0.1
# Standalone/development default. The packaged host overrides this with 0 unless
# an explicit port is configured, so the backend binds its own ephemeral port.
ASSISTANT_PORT=8765
ASSISTANT_LOG_LEVEL=INFO
# Generated by the Tauri host or scripts/dev.ps1. Use a new value each session.
ASSISTANT_SESSION_TOKEN=

# Cloud providers. Never commit real values.
DEEPGRAM_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Speech providers
ASSISTANT_STT_PROVIDER=deepgram
ASSISTANT_LLM_PROVIDER=gemini
ASSISTANT_TTS_PROVIDER=piper
WILLOW_WIS_URL=http://127.0.0.1:19000/v1/audio/transcriptions

# Piper is installed separately; voice files are not redistributed by this project.
PIPER_EXECUTABLE_PATH=
PIPER_MODEL_PATH=

# openWakeWord: run scripts/install-wake-model.ps1 after reviewing its model
# license. A bare "Jarvis" phrase requires a compatible custom ONNX model.
OPENWAKEWORD_MODEL_PATH=
OPENWAKEWORD_MELSPEC_MODEL_PATH=
OPENWAKEWORD_EMBEDDING_MODEL_PATH=
ASSISTANT_WAKE_PHRASE=hey jarvis
ASSISTANT_WAKE_SENSITIVITY=0.55
ASSISTANT_MICROPHONE_DEVICE=

# Local storage. Defaults to the platform-specific user data directory.
ASSISTANT_DATA_DIR=
ASSISTANT_SAVE_CONVERSATION_HISTORY=true

# Desktop/file safety boundaries. Empty allowlists keep developer execution disabled.
ALLOWED_FILE_ROOTS_JSON=[]
TRUSTED_SCRIPT_ROOTS_JSON=[]
TRUSTED_SCRIPT_ALLOWLIST_JSON=[]
TRUSTED_PYTHON_EXECUTABLE_PATH=
DEVELOPMENT_COMMANDS_JSON={}
PREFERRED_APPLICATIONS_JSON={}

# Optional secure production secret storage (Windows Credential Manager via keyring).
ASSISTANT_USE_CREDENTIAL_MANAGER=false
