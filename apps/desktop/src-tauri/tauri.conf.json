{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JARVIS Desktop Assistant",
  "version": "0.1.0",
  "identifier": "com.jarvis.desktop-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "JARVIS",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "category": "Utility",
    "shortDescription": "Local-first Windows desktop AI assistant",
    "longDescription": "A tray-based Windows assistant with wake-word activation, safe tool controls, Gemini reasoning, Deepgram transcription, and local Piper speech.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
